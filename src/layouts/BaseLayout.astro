---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Portfolio of Fayssal Zeggar, Data Engineer focused on Snowflake, Python, SQL, ETL/ELT pipelines, analytics enablement, and governed data platforms.",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site || "https://portfolio.fayssal-zeggar.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f4" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
