---
interface Props {
  title: string;
  summary: string;
  href: string;
  projectType: string;
  tech: string[];
}

const { title, summary, href, projectType, tech } = Astro.props;
---

<article class="project-card">
  <div>
    <span class="eyebrow">{projectType}</span>
    <h3><a href={href}>{title}</a></h3>
    <p>{summary}</p>
  </div>
  <div class="tag-row compact">
    {tech.slice(0, 6).map((item) => <span>{item}</span>)}
  </div>
  <a class="text-link" href={href}>View project</a>
</article>
